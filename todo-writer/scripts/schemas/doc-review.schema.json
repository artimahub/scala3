{
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "summary", "items", "bonus_findings"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approve", "revise"],
      "description": "approve only if every filled doc is acceptable as-is for this lens"
    },
    "summary": {
      "type": "string",
      "description": "one-line overall assessment"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["symbol", "line", "severity", "issue", "suggestion", "confidence", "needs_human"],
        "properties": {
          "symbol": { "type": "string", "description": "declaration name, e.g. Source.withReset" },
          "line": { "type": "integer", "description": "1-based line of the declaration" },
          "severity": { "type": "string", "enum": ["blocker", "nit", "ok"] },
          "issue": { "type": "string", "description": "what is wrong; empty string if severity is ok" },
          "suggestion": { "type": "string", "description": "concrete fix; empty string if severity is ok" },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "how confident you are that the documented behavior is actually correct given the code"
          },
          "needs_human": {
            "type": "boolean",
            "description": "true when a human should verify because the code does not make the intended meaning determinable"
          }
        }
      }
    },
    "bonus_findings": {
      "type": "array",
      "description": "real inaccuracies noticed in PRE-EXISTING documentation outside the reviewed diff; never affect the verdict",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["symbol", "line", "issue", "suggestion"],
        "properties": {
          "symbol": { "type": "string" },
          "line": { "type": "integer" },
          "issue": { "type": "string" },
          "suggestion": { "type": "string" }
        }
      }
    }
  }
}
